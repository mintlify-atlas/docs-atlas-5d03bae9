  "publicApiSurface": [
    "Patient Model - full_name, document_id, birth_date, medical_antecedents, allergies",
    "Appointment Model - patient_id, doctor_id, appointment_date, status",
    "Consultation Model - patient_id, doctor_id, vital signs (weight, height, BP, etc.)",
    "Prescription Model - consultation_id, medications, dosage",
    "Payment Model - patient_id, consultation_id, amount, status",
    "PatientController - index, store, show, update, destroy",
    "AppointmentController - index, store, show, update, destroy",
    "ConsultationController - index, store, show, update, destroy",
    "PrescriptionController - download, preview",
    "DoctorScheduleController - index, store",
    "PatientPortalController - appointments, prescriptions, createAppointment",
    "ReportsController - index",
    "DoctorController (Staff) - index, create, store, edit, update, destroy"
